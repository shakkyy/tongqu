# ========== 模式 ==========
# false = Mock First（不花钱，联调 UI）
# true  = 真实 API（需正确配置下方密钥）
USE_REAL_API=false

MOCK_MIN_DELAY_SEC=1.0
MOCK_MAX_DELAY_SEC=2.0

# ========== DashScope（百炼）==========
# 控制台：https://help.aliyun.com/zh/model-studio/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 文本：如 qwen-plus / qwen-max（以控制台可用模型为准）
QWEN_MODEL=qwen-plus

# 绘本静态配图：万相文生图（与 wan2.6-i2v 图生视频不同）
DASHSCOPE_IMAGE_MODEL=wanx-v1

# ========== 阿里云 AccessKey（Green 内容安全 + NLS 语音）==========
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_REGION=cn-shanghai

# NLS：在「智能语音交互」控制台创建应用后得到的 AppKey（不是 AccessKey！不要填 LTAI 开头的那串）
ALIYUN_NLS_APPKEY=your_nls_project_appkey_here
# 发音人，如 xiaoyun（女声）
ALIYUN_NLS_VOICE=xiaoyun

# Green 检测服务标识（需与控制台已开通能力一致，可按需调整）
GREEN_TEXT_SERVICE=chat_detection_pro
GREEN_IMAGE_SERVICE=baselineCheck
