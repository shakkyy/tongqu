# ========== DashScope（文本/视觉/语音）==========
# 必填：百炼 API Key
DASHSCOPE_API_KEY=

# 新加坡地域改为：https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_COMPAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 草图视觉（VL）走原生 DashScope（北京）
# 新加坡地域改为：https://dashscope-intl.aliyuncs.com/api/v1
DASHSCOPE_VL_BASE_HTTP_API_URL=https://dashscope.aliyuncs.com/api/v1

# 模型
QWEN_MODEL=qwen3.6-plus
QWEN_VL_MODEL=qwen3-vl-plus
QWEN_ASR_MODEL=qwen3-asr-flash

# ========== 阿里云 RAM（Green 内容安全 + NLS 语音 Token）==========
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_REGION=cn-shanghai
ALIYUN_NLS_APPKEY=
ALIYUN_NLS_VOICE=xiaoyun
GREEN_TEXT_SERVICE=chat_detection_pro
GREEN_IMAGE_SERVICE=baselineCheck

# ========== 绘本配图：直连 Google 或 OpenAI 兼容中转（二选一）==========
GEMINI_OPENAI_API_KEY=
GEMINI_OPENAI_BASE_URL=
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# ========== 中文风格关键词增强（可选）==========
STYLE_KEYWORD_ENHANCER_ENABLED=0
STYLE_KEYWORD_TOP_K=4
STYLE_KEYWORD_BASE_MODEL=BAAI/bge-small-zh-v1.5
STYLE_KEYWORD_BANK_PATH=./data/style_keywords.json
STYLE_KEYWORD_MODEL_DIR=./training/artifacts/style_keyword_ranker
