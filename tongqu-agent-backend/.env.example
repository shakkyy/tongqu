# ========== 阿里云百炼：故事文本 + 草图理解（千问 VL）==========
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-plus
# 草图先经 VL 转文字，再交给 QWEN_MODEL 写 JSON 故事；配图仍由 Gemini
QWEN_VL_MODEL=qwen-vl-plus

# ========== 阿里云 RAM（Green 内容安全 + NLS 语音 Token）==========
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_REGION=cn-shanghai
ALIYUN_NLS_APPKEY=
ALIYUN_NLS_VOICE=xiaoyun
GREEN_TEXT_SERVICE=chat_detection_pro
GREEN_IMAGE_SERVICE=baselineCheck

# ========== 绘本配图：直连 Google 或 OpenAI 兼容中转（二选一）==========
# 密钥：直连填 Google AI Studio Key；易步云等中转可只填 GOOGLE_API_KEY 为平台 Key，或单独填 GEMINI_OPENAI_API_KEY
GOOGLE_API_KEY=
GEMINI_OPENAI_API_KEY=

# 不填则走官方 google-genai；填则走 OpenAI SDK（如易步云 https://yibuapi.com/v1）
GEMINI_OPENAI_BASE_URL=

# 直连示例：gemini-2.0-flash-preview-image-generation
# 易步云文生图示例：gemini-2.5-flash-image-preview（以平台文档为准）
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
